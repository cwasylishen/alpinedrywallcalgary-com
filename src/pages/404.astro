---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | Alpine Drywall Calgary">
  <main class="hero" style="min-height: 100vh; text-align: center;">
    <div class="hero-bg" style="background-image: url('/assets/images/hero-background.jpg');"></div>
    <div class="wrap hero-inner" style="margin: 0 auto; padding: 4rem 0;">
      <span class="eyebrow">404</span>
      <h1>This page is not on site.</h1>
      <p class="lead">The page you're looking for doesn't exist. Head back to home.</p>
      <div class="hero-ctas" style="justify-content: center;">
        <a href="/" class="btn btn-primary">Back to home</a>
      </div>
    </div>
  </main>
</Base>
