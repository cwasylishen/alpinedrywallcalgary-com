---
import Base from '../layouts/Base.astro';
const schema = {
  "@context": "https://schema.org", "@type": "GeneralContractor",
  "name": "Alpine Drywall (Calgary) Ltd.", "url": "https://alpinedrywallcalgary.com",
  "logo": "https://alpinedrywallcalgary.com/assets/images/logo.png",
  "image": "https://alpinedrywallcalgary.com/assets/images/hero-background.jpg",
  "description": "Calgary's commercial and institutional drywall contractor since 1986. COR certified. Gold Seal management.",
  "foundingDate": "1986",
  "address": { "@type": "PostalAddress", "addressLocality": "Calgary", "addressRegion": "AB", "addressCountry": "CA" },
  "areaServed": { "@type": "City", "name": "Calgary" },
  "knowsAbout": ["Commercial drywall","Steel stud framing","Acoustical ceilings","Institutional construction","Fire-rated assemblies","Level 5 drywall finishing"]
};
---
<Base
  title="Alpine Drywall (Calgary) Ltd. | Commercial & Institutional Drywall Since 1986"
  ogTitle="Alpine Drywall (Calgary) Ltd. | Commercial & Institutional Specialists Since 1986"
  active="home"
  canonical="https://alpinedrywallcalgary.com/"
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(schema)} />
  <main>
    <section class="hero">
      <div class="hero-bg" style="background-image: url('/assets/images/hero-background.jpg');" role="img" aria-label="Commercial drywall construction site in Calgary"></div>
      <div class="wrap hero-inner">
        <span class="eyebrow">Calgary's commercial drywall specialist</span>
        <h1>Building Calgary's skyline <span class="accent">since 1986.</span></h1>
        <p class="lead">Commercial and institutional drywall, steel stud framing, and acoustical ceilings. COR certified. Gold Seal management. Four decades of Calgary work behind every bid.</p>
        <div class="hero-ctas">
          <a href="/expertise.html" class="btn btn-primary">See our work <span class="arrow" aria-hidden="true">→</span></a>
          <a href="/team.html" class="btn btn-ghost-light">Meet the team</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat"><span class="num">40+</span><span class="label">Years building Calgary</span></div>
          <div class="hero-stat"><span class="num">2001</span><span class="label">COR certified since</span></div>
          <div class="hero-stat"><span class="num">25+</span><span class="label">Years leadership tenure</span></div>
        </div>
      </div>
    </section>

    <section>
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Why Alpine</span>
          <h2>Predictable work in an unpredictable trade.</h2>
          <p class="lead">Most of construction runs on optimism and crossed fingers. We run on tenure, ownership, and a track record we can actually point to.</p>
        </div>
        <div class="pillars">
          <article class="pillar">
            <div class="pillar-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2M13 9h2M9 13h2M13 13h2M9 17h2M13 17h2"/></svg></div>
            <h3>Stability</h3>
            <p>Our leadership averages 25+ years with the company. The person bidding your job is the person who finishes it.</p>
          </article>
          <article class="pillar">
            <div class="pillar-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 5.5 3.5 10 8 11 4.5-1 8-5.5 8-11V6l-8-4z"/><path d="M9 12l2 2 4-4"/></svg></div>
            <h3>Safety</h3>
            <p>COR certified since 2001. NCSO on staff. Daily field hazard assessments. The job stays on schedule because nothing on it goes sideways.</p>
          </article>
          <article class="pillar">
            <div class="pillar-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
            <h3>Ownership</h3>
            <p>Owner-operated. We own our scissor lifts, scaffolding, and finishing kit. When rentals dry up in the city, our schedule doesn't budge.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-dark">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">What we build</span>
          <h2>Steel stud, drywall, and ceilings, top to bottom.</h2>
          <p class="lead">Two trades, executed by crews who run them every day on commercial sites across Calgary and southern Alberta.</p>
        </div>
        <div class="services">
          <article class="service-card">
            <div class="img"><img src="/assets/images/steel-stud-framing-calgary-commercial.jpg" alt="Steel stud framing on a commercial Calgary build" loading="lazy" width="800" height="500" /></div>
            <div class="body">
              <h3>Steel stud framing &amp; drywall</h3>
              <p>Complete interior framing and drywall packages for commercial, institutional, and tenant improvement projects. Clean lines, square corners, finishes ready for paint.</p>
              <ul class="features">
                <li>Metal stud and track framing systems</li>
                <li>Fire-rated and acoustic-rated assemblies</li>
                <li>Moisture-resistant and abuse-resistant board</li>
                <li>Level 4 and Level 5 finishes</li>
              </ul>
            </div>
          </article>
          <article class="service-card">
            <div class="img"><img src="/assets/images/suspended-ceiling-installation-calgary-office.jpg" alt="Acoustical T-bar ceiling installation in a Calgary commercial space" loading="lazy" width="800" height="500" /></div>
            <div class="body">
              <h3>Acoustical ceilings</h3>
              <p>Suspended T-bar grids, drywall ceilings, and specialty acoustical work. We coordinate with mechanical, electrical, and lighting trades so the ceiling drops in clean the first time.</p>
              <ul class="features">
                <li>T-bar grid systems from every major supplier</li>
                <li>Acoustical and decorative tile selection</li>
                <li>Custom suspension heights and bulkheads</li>
                <li>Integration with HVAC, sprinkler, and lighting</li>
              </ul>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="wrap">
        <div class="split split-reverse">
          <div>
            <span class="eyebrow">Equipment</span>
            <h2>We own our fleet. So we own the schedule.</h2>
            <p>Rental delays do not show up on our jobs because we don't rent the critical kit. Scissor lifts, scaffolding, finishing equipment: we own it, we maintain it, and it shows up when it's supposed to.</p>
            <p>Owning the fleet keeps your project moving on the days nobody else can find a lift in the city.</p>
            <ul class="checklist">
              <li>In-house fleet of electric and rough-terrain scissor lifts</li>
              <li>Commercial scaffolding and mast climbers</li>
              <li>Equipment inspected and certified on a fixed maintenance cycle</li>
            </ul>
          </div>
          <div class="img-frame"><img src="/assets/images/suspended-ceiling-installation-calgary-office.jpg" alt="Alpine Drywall crew working in a Calgary commercial interior" loading="lazy" width="800" height="600" /></div>
        </div>
      </div>
    </section>

    <section class="section-dark">
      <div class="wrap">
        <div class="split">
          <div class="img-frame"><img src="/assets/images/alpine-drywall-calgary-commercial-team.jpg" alt="Alpine Drywall leadership team at a Calgary commercial project" loading="lazy" width="800" height="600" /></div>
          <div>
            <span class="eyebrow">Leadership</span>
            <h2>People who learned the trade with their hands.</h2>
            <p>Our directors, estimators, and superintendents started in the field. The result is a leadership team that reads drawings, understands the work in front of them, and respects the crews doing it.</p>
            <ul class="checklist">
              <li>Gold Seal Certified project management</li>
              <li>Leadership tenure averaging 25+ years with Alpine</li>
              <li>NCSO certified safety on every project</li>
            </ul>
            <p style="margin-top: 1.5rem;"><a href="/team.html" class="btn btn-ghost-light">Meet the team <span class="arrow">→</span></a></p>
          </div>
        </div>
      </div>
    </section>

    <section class="assoc" aria-label="Industry memberships">
      <div class="wrap">
        <p class="assoc-label">Proud member of</p>
        <div class="assoc-row">
          <img src="/assets/images/cca-logo.png" alt="Calgary Construction Association member" loading="lazy" />
          <img src="/assets/images/awca-logo.png" alt="Alberta Wall and Ceiling Association member" loading="lazy" />
          <img src="/assets/images/acsa-logo.png" alt="Alberta Construction Safety Association member" loading="lazy" />
          <img src="/assets/images/cor.png" alt="COR Certificate of Recognition" loading="lazy" />
        </div>
      </div>
    </section>
  </main>
</Base>
